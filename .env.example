# =========================
# JIRA (required)
# =========================
JIRA_DOMAIN=oneline.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token
# Jira page opened by the "Kiểm tra trên Jira" button in Google Chat.
JIRA_CHECK_URL=https://oneline.atlassian.net/projects/YOUR_PROJECT?selectedItem=com.atlassian.plugins.atlassian-connect-plugin:com.gebsun.atlassian.reports.free__report

# Public base URL of your web service, used to build retry open-link in webhook mode.
APP_BASE_URL=https://url_api.vercel.app

# Protects /reports/run and /reports/retry endpoints (required for Vercel cron)
CRON_SECRET=replace_with_long_random_secret


# =========================
# CHAT DELIVERY MODE
# =========================
# webhook: use incoming webhook URL
# app: use Google Chat App + service account
GOOGLE_CHAT_MODE=webhook
# Required only when GOOGLE_CHAT_MODE=webhook
WEBHOOK=https://chat.googleapis.com/v1/spaces/xxx/messages?key=xxx&token=xxx

# Required only when GOOGLE_CHAT_MODE=app
# Format example: spaces/AAAA12345
GOOGLE_CHAT_SPACE=
GOOGLE_CHAT_SERVICE_ACCOUNT_EMAIL=
# Keep newline escaped as \n in .env
GOOGLE_CHAT_SERVICE_ACCOUNT_PRIVATE_KEY=

# =========================
# OPTIONAL
# =========================
# Preferred timezone for report time/date rendering.
# If set, REPORT_TIMEZONE has highest priority.
REPORT_TIMEZONE=Asia/Ho_Chi_Minh

# Fallback timezone when REPORT_TIMEZONE is empty.
TZ=Asia/Ho_Chi_Minh

# Force report for a specific date (YYYY-MM-DD). Leave empty for today in TZ.
REPORT_DATE=

# Enable detailed worklog aggregation debug logs.
# Supported truthy values: 1, true, yes, on
REPORT_DEBUG=

# Optional author filter for debug logs, comma-separated.
# Example: Tyler,Leser,Lien Mach
REPORT_DEBUG_AUTHORS=

# Optional API base path. Keep empty to auto-detect on Vercel.
# API_BASE_PATH=/api
API_BASE_PATH=